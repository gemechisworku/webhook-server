# =============================================================================
# Server
# =============================================================================

# Port the HTTP server listens on. Defaults to 3000 if unset.
# Where to get: choose any free port locally; on Render, PORT is set automatically.
PORT=3000


# =============================================================================
# Resend (POST /webhooks/resend)
# =============================================================================

# Svix signing secret used to verify Resend webhook signatures.
# Where to get: Resend Dashboard → Webhooks → your endpoint → Signing Secret
# (Resend uses Svix; this is the "whsec_..." or similar secret shown there.)
RESEND_WEBHOOK_SECRET=


# =============================================================================
# Cal.com (POST /webhooks/cal or POST /)
# =============================================================================

# Shared secret for HMAC SHA-256 verification (x-cal-signature-256 header).
# Where to get: Cal.com → Settings → Developer → Webhooks → secret for your webhook.
CAL_WEBHOOK_SECRET=


# =============================================================================
# HubSpot webhooks (POST /webhooks/hubspot)
# =============================================================================

# App client secret used to verify HubSpot webhook signatures (v1 / v2 / v3).
# Same credential as OAuth client secret for a typical HubSpot app.
# Where to get: HubSpot Developer Account → your app → Auth (or app settings) → Client secret
HUBSPOT_CLIENT_SECRET=


# =============================================================================
# HubSpot OAuth / MCP (GET /?code=... callback)
# =============================================================================

# Public app identifier for the authorization code → token exchange.
# Where to get: same HubSpot app → Auth → Client ID
HUBSPOT_CLIENT_ID=

# Redirect URI sent in the token request. Must match EXACTLY the redirect URL
# registered on the HubSpot app (and the redirect_uri used in the authorize URL),
# including https, host, path, and trailing slash if HubSpot has one.
# Where to get: copy from HubSpot app → Auth → Redirect URLs (pick the one you use).
# If unset, the server derives https://<request-host>/ from the incoming callback.
HUBSPOT_REDIRECT_URI=

# PKCE code_verifier. Must be the same value used to build code_challenge for the
# install / authorize step (required for MCP OAuth 2.1 with HubSpot).
# Where to get: from your OAuth/MCP setup—the verifier paired with the challenge you
# sent to HubSpot. If MCP inspector documents a fixed verifier or lets you copy it,
# paste that value here. See:
# https://developers.hubspot.com/docs/apps/developer-platform/build-apps/integrate-with-the-remote-hubspot-mcp-server
HUBSPOT_CODE_VERIFIER=

# OAuth token endpoint. Override only if HubSpot documents a new URL.
# Default: https://api.hubspot.com/oauth/2026-03/token
# Where to get: HubSpot docs → Manage OAuth access tokens (2026-03 API)
HUBSPOT_OAUTH_TOKEN_URL=

# If set to 1, the OAuth success page includes access_token and refresh_token in the
# response body (use only briefly to copy tokens, then remove or set to 0).
# Where to get: N/A — local/debug flag only; never enable in production long-term.
HUBSPOT_OAUTH_SHOW_TOKENS=0
